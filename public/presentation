          <div style="display:flex;flex-direction:column;gap:.5rem;">
            <div style="display:flex;align-items:center;gap:.7rem;font-size:.82rem;color:var(--dark);"><div style="width:5px;height:5px;border-radius:50%;background:var(--red);flex-shrink:0;"></div>Event created once — all formats generated</div>
