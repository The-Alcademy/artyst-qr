</div>

<!-- 2 THE PROBLEM -->
<div class="slide bg-warm">
  <div class="slide-inner">
    <div class="two-col">
      <div>
        <div class="eyebrow dark a1">The starting point</div>
        <div class="rule dark a2"></div>
