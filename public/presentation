      <div class="a5" style="display:flex;flex-direction:column;gap:1rem;">
        <div class="card light" style="padding:1.2rem;">
          <div style="font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#bbb;margin-bottom:.6rem;">Without this system</div>
