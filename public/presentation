<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --cream:#faf8f4;--warm:#f2ede6;--gold:#8a6a2e;--gold-light:#c8a96e;
  --red:#c0392b;--dark:#1a1a18;--mid:#3a3a38;--muted:#777770;--border:#ddd9d0;
}
html,body{width:100%;height:100%;overflow:hidden;background:var(--dark);font-family:'DM Sans',sans-serif;}
.deck{width:100%;height:100%;position:relative;overflow:hidden;}
.slide{position:absolute;inset:0;display:flex;flex-direction:column;opacity:0;pointer-events:none;transition:opacity .5s ease,transform .5s ease;transform:translateY(30px);}
.slide.active{opacity:1;pointer-events:all;transform:translateY(0);}
.slide.exit{opacity:0;transform:translateY(-30px);}
.bg-cream{background:var(--cream);}
.bg-dark{background:var(--dark);}
.bg-mid{background:#111110;}
.bg-warm{background:var(--warm);}
.bg-grid{background:var(--dark);background-image:linear-gradient(rgba(200,169,110,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(200,169,110,.04) 1px,transparent 1px);background-size:40px 40px;}
.slide-inner{flex:1;display:flex;flex-direction:column;justify-content:center;padding:5vh 8vw;max-width:1400px;margin:0 auto;width:100%;}
.slide-inner.wide{max-width:1600px;}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:5vw;align-items:center;}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2vw;}
.four-col{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:1.5vw;}
.eyebrow{font-family:'DM Mono',monospace;font-size:clamp(.65rem,1vw,.85rem);letter-spacing:.18em;text-transform:uppercase;color:var(--gold-light);margin-bottom:1.2rem;opacity:.8;}
.eyebrow.dark{color:var(--gold);}
h1.display{font-family:'Playfair Display',serif;font-size:clamp(2.5rem,6vw,5.5rem);line-height:1.05;font-weight:900;color:var(--cream);letter-spacing:-.02em;margin-bottom:1.5rem;}
h1.display .accent{color:var(--gold-light);}
h1.display.dark-text{color:var(--dark);}
h2.section{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,3.5rem);line-height:1.1;font-weight:700;color:var(--cream);margin-bottom:1rem;}
h2.section.dark-text{color:var(--dark);}
h3.card-title{font-family:'Playfair Display',serif;font-size:clamp(1rem,1.8vw,1.4rem);font-weight:700;color:var(--cream);margin-bottom:.4rem;}
h3.card-title.dark-text{color:var(--dark);}
.body-text{font-size:clamp(.9rem,1.4vw,1.1rem);color:rgba(250,248,244,.7);line-height:1.75;max-width:56ch;}
.body-text.dark-text{color:var(--mid);}
.rule{width:3rem;height:2px;background:var(--red);margin-bottom:1.5rem;}
.rule.gold{background:var(--gold-light);}
.rule.dark{background:var(--red);}
.big-number{font-family:'Playfair Display',serif;font-size:clamp(3.5rem,8vw,7rem);font-weight:900;color:var(--gold-light);line-height:1;letter-spacing:-.04em;}
.big-number.dark{color:var(--dark);}
.big-label{font-size:clamp(.8rem,1.2vw,1rem);color:rgba(250,248,244,.5);letter-spacing:.06em;text-transform:uppercase;margin-top:.3rem;}
.big-label.dark{color:var(--muted);}
.tag{display:inline-block;padding:.25rem .7rem;border:1px solid rgba(200,169,110,.3);border-radius:2px;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gold-light);font-family:'DM Mono',monospace;}
.card{background:rgba(255,255,255,.04);border:1px solid rgba(200,169,110,.12);border-radius:6px;padding:1.5vw;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--red),transparent);}
.card.light{background:#fff;border-color:var(--border);}
.card.gold-border{border-color:rgba(200,169,110,.35);}
.pull-quote{font-family:'Playfair Display',serif;font-size:clamp(1.1rem,2vw,1.6rem);font-style:italic;line-height:1.5;color:var(--cream);border-left:3px solid var(--red);padding-left:1.5rem;margin:1.5rem 0;}
.pull-quote.dark{color:var(--dark);}
.progress{position:fixed;bottom:0;left:0;right:0;height:2px;background:rgba(200,169,110,.15);z-index:100;}
.progress-bar{height:100%;background:var(--gold-light);transition:width .4s ease;}
.nav{position:fixed;bottom:2rem;right:2.5rem;display:flex;gap:.6rem;z-index:100;}
.nav-btn{
  width:2.8rem;height:2.8rem;border-radius:50%;
  border:1.5px solid rgba(200,169,110,.6);
  background:rgba(26,26,24,.85);
  backdrop-filter:blur(8px);
  color:var(--gold-light);cursor:pointer;font-size:1.2rem;
  display:flex;align-items:center;justify-content:center;
  transition:all .15s;
  box-shadow:0 2px 12px rgba(0,0,0,.5);
}
.nav-btn:hover{background:rgba(200,169,110,.2);border-color:var(--gold-light);box-shadow:0 2px 20px rgba(200,169,110,.25);}
.slide-counter{
  position:fixed;bottom:2.5rem;left:2.5rem;z-index:100;
  font-family:'DM Mono',monospace;font-size:.72rem;letter-spacing:.1em;
  color:rgba(200,169,110,.6);
  background:rgba(26,26,24,.75);backdrop-filter:blur(8px);
  padding:.3rem .7rem;border-radius:20px;border:1px solid rgba(200,169,110,.2);
}
.watermark{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(200,169,110,.18);z-index:100;white-space:nowrap;}
.channel-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
.channel-card{background:rgba(255,255,255,.03);border:1px solid rgba(200,169,110,.12);border-radius:6px;padding:1.2rem;text-align:center;}
.channel-icon{font-size:1.8rem;margin-bottom:.5rem;}
.channel-name{font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gold-light);margin-bottom:.3rem;}
.channel-num{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:700;color:var(--cream);}
.channel-sub{font-size:.65rem;color:var(--muted);}
.cost-table{width:100%;border-collapse:collapse;margin-top:1rem;}
.cost-table th{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);padding:.5rem .8rem;border-bottom:1px solid var(--border);text-align:left;}
.cost-table td{font-size:.82rem;padding:.55rem .8rem;border-bottom:1px solid rgba(0,0,0,.05);color:var(--mid);vertical-align:top;}
.cost-table tr.total td{color:var(--dark);font-weight:600;border-top:1px solid var(--border);border-bottom:none;}
.cost-table .price{font-family:'DM Mono',monospace;color:var(--gold);font-weight:500;text-align:right;}
.cost-table .red{color:var(--red);}
.stack-row{display:flex;align-items:center;gap:1rem;padding:.7rem 0;border-bottom:1px solid rgba(0,0,0,.06);}
.stack-tag{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.08em;color:var(--gold);background:rgba(138,106,46,.08);padding:.2rem .5rem;border-radius:2px;flex-shrink:0;min-width:70px;text-align:center;}
.stack-desc{font-size:.82rem;color:var(--mid);flex:1;}
.stack-status{font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;padding:.15rem .4rem;border-radius:2px;flex-shrink:0;}
.stack-status.live{background:rgba(42,106,42,.12);color:#2a7a2a;border:1px solid rgba(42,106,42,.2);}
.fp-preview{background:#fff;border-radius:4px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.15);}
.fp-hdr{background:var(--warm);padding:.7rem .9rem .5rem;border-bottom:1px solid var(--border);}
.fp-venue{font-size:.48rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);}
.fp-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--dark);}
.fp-body{padding:.7rem .9rem;flex:1;}
.fp-row{display:flex;justify-content:space-between;padding:.18rem 0;border-bottom:.4px solid #f0ece7;font-size:.58rem;color:var(--dark);}
.fp-row .pr{font-weight:600;}
.fp-cat{font-size:.44rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin:.45rem 0 .15rem;font-weight:600;}
.fp-cta{padding:.5rem .9rem;border-top:1px solid var(--border);display:flex;align-items:center;gap:.5rem;background:var(--warm);}
.qr-box{border-radius:2px;display:grid;gap:2px;padding:3px;}
.qr-cell{background:#fff;border-radius:1px;}
.dark-qr{background:var(--dark);}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
.slide.active .a1{animation:fadeUp .5s .1s both}
.slide.active .a2{animation:fadeUp .5s .2s both}
.slide.active .a3{animation:fadeUp .5s .3s both}
.slide.active .a4{animation:fadeUp .5s .4s both}
.slide.active .a5{animation:fadeUp .5s .5s both}
.slide.active .a6{animation:fadeUp .5s .6s both}
@media(max-width:900px){.two-col,.three-col,.four-col,.channel-grid{grid-template-columns:1fr;}h1.display{font-size:2rem;}h2.section{font-size:1.5rem;}}

  /* ── Password gate ── */
  .gate{position:fixed;inset:0;background:var(--dark,#1a1a18);z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1.5rem;}
  .gate-logo{width:36px;height:36px;background:#c0392b;border-radius:4px;}
  .gate-title{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;color:#faf8f4;letter-spacing:-.01em;}
  .gate-sub{font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(200,169,110,.6);}
  .gate-form{display:flex;flex-direction:column;align-items:center;gap:.8rem;margin-top:.5rem;}
  .gate-input{background:rgba(255,255,255,.06);border:1px solid rgba(200,169,110,.25);border-radius:4px;padding:.7rem 1.2rem;font-size:1rem;color:#faf8f4;text-align:center;letter-spacing:.08em;width:220px;outline:none;font-family:'DM Mono',monospace;}
  .gate-input:focus{border-color:rgba(200,169,110,.6);}
  .gate-input.shake{animation:shake .35s ease;}
  .gate-btn{background:#c0392b;color:#fff;border:none;border-radius:4px;padding:.65rem 2rem;font-size:.88rem;font-weight:500;cursor:pointer;letter-spacing:.04em;transition:background .15s;}
  .gate-btn:hover{background:#a93226;}
  .gate-err{font-size:.75rem;color:#c0392b;font-family:'DM Mono',monospace;letter-spacing:.06em;min-height:1em;}
  @keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-8px)}75%{transform:translateX(8px)}}
</style>
</head>
<body>
<div class="gate" id="gate">
  <div class="gate-logo"></div>
  <div class="gate-title">The Artyst</div>
  <div class="gate-sub">OtherSyde Ltd · Confidential</div>
  <div class="gate-form">
    <input class="gate-input" id="gate-input" type="password" placeholder="Password" autocomplete="off"
      onkeydown="if(event.key==='Enter')checkGate()"/>
    <button class="gate-btn" onclick="checkGate()">Enter</button>
    <div class="gate-err" id="gate-err"></div>
  </div>
</div>
<script>
(function(){
  if(sessionStorage.getItem('artyst-access')==='1'){
    document.getElementById('gate').style.display='none';
    document.body.style.overflow='hidden';
  }
})();
function checkGate(){
  var v=document.getElementById('gate-input').value;
  if(v==='gotabike'){
    sessionStorage.setItem('artyst-access','1');
    document.getElementById('gate').style.display='none';
    document.body.style.overflow='hidden';
  } else {
    var inp=document.getElementById('gate-input');
    document.getElementById('gate-err').textContent='Incorrect password.';
    inp.value='';inp.classList.add('shake');
    setTimeout(function(){inp.classList.remove('shake');},400);
  }
}
</script>

<div class="deck">

<!-- 1 COVER -->
<div class="slide bg-dark active">
  <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--red),var(--gold-light),transparent)"></div>
  <div class="slide-inner" style="justify-content:space-between;padding-top:8vh;padding-bottom:8vh;">
    <div class="a1" style="display:flex;align-items:center;gap:.8rem;">
      <div style="width:24px;height:24px;background:var(--red);border-radius:2px;"></div>
      <span style="font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(200,169,110,.55);">OtherSyde Ltd · The Artyst · Cambridge</span>
    </div>
    <div>
