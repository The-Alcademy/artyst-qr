</div>
<div class="slide-counter" id="ctr"></div>
<div class="watermark">OtherSyde Ltd — Confidential</div>

<script>
const TOTAL=10,slides=document.querySelectorAll('.slide');
let cur=0;
function show(n){
  slides[cur].classList.remove('active');slides[cur].classList.add('exit');
  setTimeout(()=>slides[cur].classList.remove('exit'),500);
  cur=((n%TOTAL)+TOTAL)%TOTAL;slides[cur].classList.add('active');
  document.getElementById('pb').style.width=((cur+1)/TOTAL*100)+'%';
  document.getElementById('ctr').textContent=(cur+1)+' / '+TOTAL;
}
function go(d){show(cur+d);}
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'||e.key==='ArrowDown'||e.key===' ')go(1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp')go(-1);
});
let tx=0;
document.addEventListener('touchstart',e=>tx=e.touches[0].clientX);
document.addEventListener('touchend',e=>{const d=e.changedTouches[0].clientX-tx;if(Math.abs(d)>50)go(d<0?1:-1);});
document.getElementById('pb').style.width=(1/TOTAL*100)+'%';
document.getElementById('ctr').textContent='1 / '+TOTAL;
</script>
